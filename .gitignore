# Free Pascal compiled units and object files
*.o
*.or
*.obj
*.a
*.ppu
*.rst
*.compiled

# Compiled Windows resources (but NOT mario.res — it's tracked so
# the build works without windres installed)
*.res
!mario.res

# Avoid comitting songs for now
*.ogg

# Executables
*.exe

# Game saves, config files, replays and hiscores
*.cfg
*.sav
*.rpl
*.his

# Editor backup files
*.bak
*.~*
*~

# Log files
*.log
*.txt

# Build output directories
OUT/
editor/OUT/

# Editor dependencies (cloned from GitHub)
editor/ImGui-Pascal/

# ImGui / editor state files
editor_layout.ini
editor_window.ini

# OS junk
Thumbs.db
Desktop.ini
.DS_Store
nul
